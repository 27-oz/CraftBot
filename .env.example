# ============================
# CraftBot Environment Config
# ============================

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_token_here

# Twitch API (optional — only needed for Twitch live alerts)
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# RSSHub base URL for TikTok tracking (default public instance — may be rate limited)
# Self-host for reliability: https://docs.rsshub.app/install/
RSSHUB_URL=https://rsshub.app
